# Keep cross-platform text files at LF so they don't churn between Windows/macOS.
# Shell scripts in particular break on macOS/Linux with CRLF ("bad interpreter ^M").
*.sh    text eol=lf
*.patch text eol=lf
*.md    text eol=lf
*.ps1   text eol=lf
# The pkg installer scripts are extensionless but are still shell.
MacHost/installer/scripts/postinstall text eol=lf
MacHost/installer/scripts/preinstall text eol=lf
